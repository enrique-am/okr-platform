# Copy this file to .env.local and fill in real values
# Never commit .env.local — it is gitignored

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

OPENAI_API_KEY=""

# Resend (transactional email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@am.com.mx"

# App URL (used in emails and cron jobs)
APP_URL="http://localhost:3000"

# Cron job secret — set a long random string and pass it as
# Authorization: Bearer <CRON_SECRET> when calling /api/cron/* routes
CRON_SECRET=""

# PostHog — product analytics
# Get your key at https://app.posthog.com (or your self-hosted instance)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry — error tracking
# The DSN is public by design; NEXT_PUBLIC_ makes it available client-side.
# Get your DSN at https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=""
# Optional: set to upload source maps for readable stack traces in Sentry.
# Create a token at https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=""
